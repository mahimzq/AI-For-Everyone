#!/usr/bin/expect -f
set timeout -1
set password "Mahim@9898@@"
set host "root@187.124.113.85"
set dir "/var/www/ai4you.mindsetai.cloud"

# Upload chatSocket.js
spawn scp ./server/chatSocket.js $host:$dir/server/chatSocket.js
expect {
    "yes/no" { send "yes\r"; exp_continue }
    "password:" { send "$password\r" }
}
expect eof

# Upload webauthn.js (biometric fix)
spawn scp ./server/routes/webauthn.js $host:$dir/server/routes/webauthn.js
expect {
    "password:" { send "$password\r" }
}
expect eof

# SSH in to install openai, update .env, and reload PM2
spawn ssh $host
expect {
    "password:" { send "$password\r" }
}
expect "# "
send "cd $dir/server && npm install openai\r"
expect "# "
send "grep -q OPENAI_API_KEY $dir/server/.env || echo '\\n# OpenAI (ChatGPT)\\nOPENAI_API_KEY=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' >> $dir/server/.env\r"
expect "# "
send "cd $dir && pm2 reload ecosystem.config.js --env production\r"
expect "# "
send "sleep 2 && curl -s http://127.0.0.1:5001/api/health\r"
expect "# "
send "exit\r"
expect eof
