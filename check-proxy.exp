#!/usr/bin/expect -f
log_file -noappend /tmp/proxy_check.log
set timeout 30
set password "Mahim@9898@@"

spawn ssh  root@187.124.113.85
expect {
    "yes/no" { send "yes\r"; exp_continue }
    "password:" { send "$password\r" }
}
expect "$ "
send "cat /var/www/ai4you.mindsetai.cloud/public_html/proxy.php\r"
expect "$ "
send "cat /var/www/ai4you.mindsetai.cloud/public_html/.htaccess\r"
expect "$ "
send "exit\r"
expect eof
