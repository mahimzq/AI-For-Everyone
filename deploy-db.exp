spawn scp -P 65002 server/models/Registration.js root@187.124.113.85:/var/www/ai4you.mindsetai.cloud/server/models/Registration.js
expect "password:"
send "$password\r"
expect eof

spawn scp -P 65002 server/models/ContactMessage.js root@187.124.113.85:/var/www/ai4you.mindsetai.cloud/server/models/ContactMessage.js
expect "password:"
send "$password\r"
